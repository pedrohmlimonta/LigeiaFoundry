<div class="ligeia-item-body equipamento">
  {{> systems/ligeia-rpg/templates/item/partials/header.hbs}}

  <div class="lig-item-row">
    <label>Categoria
      <input type="text" name="system.category" value="{{system.category}}" placeholder="Arma, Armadura, Suprimento..."/>
    </label>
    <label>Qtd.
      <input type="number" name="system.qty" value="{{system.qty}}" min="0"/>
    </label>
    <label>Peso
      <input type="number" name="system.weight" value="{{system.weight}}" min="0" step="0.1"/>
    </label>
    <label>Preço
      <input type="text" name="system.price" value="{{system.price}}" placeholder="ex: 50 Vo"/>
    </label>
  </div>

  <label class="lig-full">Notas / propriedades
    <input type="text" name="system.notes" value="{{system.notes}}" placeholder="Versátil, alcance, penalidade..."/>
  </label>

  <div class="lig-desc-block">
    <div class="lig-section-title">Descrição</div>
    {{#if editable}}
    <textarea name="system.description" rows="3">{{system.description}}</textarea>
    {{else}}<div class="lig-rendered">{{{enrichedDescription}}}</div>{{/if}}
  </div>

  {{> systems/ligeia-rpg/templates/item/partials/action.hbs}}
  {{> systems/ligeia-rpg/templates/item/partials/mode.hbs}}
  {{> systems/ligeia-rpg/templates/item/partials/effects.hbs}}
  {{> systems/ligeia-rpg/templates/item/partials/costs.hbs}}
</div>
